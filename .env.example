# Copy to .env and fill in. .env is gitignored — never commit real values.

# --- Model providers ---
# OpenRouter: free-tier hosted models. https://openrouter.ai/keys
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# Ollama: local models. No key needed.
OLLAMA_BASE_URL=http://localhost:11434

# --- Model routing (see sentinel/models/router.py) ---
# Tier assignments. Any value may be "ollama:<model>" or "openrouter:<model>".
MODEL_PLANNER=openrouter:nvidia/nemotron-3-super-120b-a12b:free
MODEL_REASONER=openrouter:nvidia/nemotron-3-super-120b-a12b:free
MODEL_WORKER=ollama:llama3.2:latest
MODEL_TRIAGE=ollama:llama3.2:latest
MODEL_EMBED=ollama:nomic-embed-text:latest

# Triage backend: "baseline" (prompted general model) or "finetuned" (Phase 6 QLoRA model)
TRIAGE_BACKEND=baseline

# --- Postgres (checkpointer + pgvector store) ---
POSTGRES_USER=sentinel
POSTGRES_PASSWORD=sentinel
POSTGRES_DB=sentinel
POSTGRES_HOST=localhost
POSTGRES_PORT=5433
DATABASE_URL=postgresql://sentinel:sentinel@localhost:5433/sentinel

# --- Observability (Phase 7) ---
LANGSMITH_TRACING=true
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=sentinel

# --- Integrations ---
GITHUB_TOKEN=
HUGGINGFACE_TOKEN=

# Repository monitoring (optional). Whose repos to watch, and an optional
# comma-separated allowlist (leave GITHUB_WATCH empty to watch every repo the
# token can see).
GITHUB_OWNER=GautamRaju18
GITHUB_WATCH=

# --- Safety rails ---
# Hard cap on investigate->reflect cycles before forcing a conclusion
MAX_INVESTIGATION_LOOPS=4
# Never auto-execute remediation above this blast radius, regardless of confidence
MAX_AUTO_BLAST_RADIUS=low
# Require human approval for every remediation, even low blast radius
ALWAYS_REQUIRE_APPROVAL=true
